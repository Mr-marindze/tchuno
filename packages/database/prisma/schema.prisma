generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  workerProfile WorkerProfile?
  jobsAsClient Job[]      @relation("ClientJobs")
  reviewsGiven Review[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workerProfiles WorkerProfileCategory[]
  jobs        Job[]

  @@index([isActive, sortOrder])
}

model WorkerProfile {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  bio             String?
  location        String?
  hourlyRate      Int?
  experienceYears Int                     @default(0)
  isAvailable     Boolean                 @default(true)
  ratingAvg       Decimal                 @default(0) @db.Decimal(3, 2)
  ratingCount     Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      WorkerProfileCategory[]
  jobs            Job[]
  reviews         Review[]

  @@index([isAvailable, updatedAt])
}

model WorkerProfileCategory {
  workerProfileId String
  categoryId      String
  createdAt       DateTime      @default(now())
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, categoryId])
  @@index([categoryId])
}

model Job {
  id              String       @id @default(cuid())
  clientId        String
  workerProfileId String
  categoryId      String
  pricingMode     JobPricingMode @default(FIXED_PRICE)
  title           String
  description     String
  budget          Int?
  quotedAmount    Int?
  quoteMessage    String?
  status          JobStatus    @default(REQUESTED)
  acceptedAt      DateTime?
  startedAt       DateTime?
  scheduledFor    DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledBy      String?
  cancelReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  client          User         @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  review          Review?

  @@index([clientId, status, createdAt])
  @@index([workerProfileId, status, createdAt])
  @@index([status, createdAt])
  @@index([pricingMode, status, createdAt])
}

model Review {
  id              String        @id @default(cuid())
  jobId           String        @unique
  workerProfileId String
  reviewerId      String
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reviewer        User          @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([workerProfileId, createdAt])
  @@index([reviewerId, createdAt])
}

enum JobStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum JobPricingMode {
  FIXED_PRICE
  QUOTE_REQUEST
}

enum UserRole {
  USER
  ADMIN
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  refreshTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([userId, revokedAt])
  @@index([userId, lastUsedAt])
}
