generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  workerProfile WorkerProfile?
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workerProfiles WorkerProfileCategory[]

  @@index([isActive, sortOrder])
}

model WorkerProfile {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  bio             String?
  location        String?
  hourlyRate      Int?
  experienceYears Int                     @default(0)
  isAvailable     Boolean                 @default(true)
  ratingAvg       Decimal                 @default(0) @db.Decimal(3, 2)
  ratingCount     Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      WorkerProfileCategory[]

  @@index([isAvailable, updatedAt])
}

model WorkerProfileCategory {
  workerProfileId String
  categoryId      String
  createdAt       DateTime      @default(now())
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, categoryId])
  @@index([categoryId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  refreshTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([userId, revokedAt])
  @@index([userId, lastUsedAt])
}
