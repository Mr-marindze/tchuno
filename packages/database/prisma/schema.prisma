generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String              @id @default(cuid())
  email                   String              @unique
  name                    String?
  passwordHash            String
  role                    UserRole            @default(USER)
  adminSubrole            AdminSubrole?
  isActive                Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  sessions                Session[]
  workerProfile           WorkerProfile?
  jobsAsClient            Job[]               @relation("ClientJobs")
  reviewsGiven            Review[]
  auditLogs               AuditLog[]
  reauthChallenges        ReauthChallenge[]
  updatedPlatformSettings PlatformSetting[]   @relation("PlatformSettingUpdatedBy")
  customerPaymentIntents  PaymentIntent[]     @relation("PaymentIntentCustomer")
  providerPaymentIntents  PaymentIntent[]     @relation("PaymentIntentProvider")
  customerServiceRequests ServiceRequest[]    @relation("CustomerServiceRequests")
  providerProposals       Proposal[]          @relation("ProviderProposals")
  requestInvitations      RequestInvitation[] @relation("RequestInvitationProvider")
  jobsAsCustomer          Job[]               @relation("JobCustomer")
  jobsAsProvider          Job[]               @relation("JobProvider")
  createdLedgerEntries    LedgerEntry[]       @relation("LedgerEntryCreatedBy")
  providerPayouts         Payout[]            @relation("PayoutProviderUser")
  requestedPayouts        Payout[]            @relation("PayoutRequestedBy")
  approvedPayouts         Payout[]            @relation("PayoutApprovedBy")
  requestedRefunds        RefundRequest[]     @relation("RefundRequestedBy")
  approvedRefunds         RefundRequest[]     @relation("RefundApprovedBy")
}

model Category {
  id              String                  @id @default(cuid())
  name            String                  @unique
  slug            String                  @unique
  description     String?
  isActive        Boolean                 @default(true)
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  workerProfiles  WorkerProfileCategory[]
  jobs            Job[]
  serviceRequests ServiceRequest[]

  @@index([isActive, sortOrder])
}

model WorkerProfile {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  publicName      String?
  bio             String?
  location        String?
  hourlyRate      Int?
  experienceYears Int                     @default(0)
  isAvailable     Boolean                 @default(true)
  ratingAvg       Decimal                 @default(0) @db.Decimal(3, 2)
  ratingCount     Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      WorkerProfileCategory[]
  jobs            Job[]
  reviews         Review[]

  @@index([isAvailable, updatedAt])
}

model WorkerProfileCategory {
  workerProfileId String
  categoryId      String
  createdAt       DateTime      @default(now())
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, categoryId])
  @@index([categoryId])
}

model ServiceRequest {
  id                 String               @id @default(cuid())
  customerId         String
  categoryId         String
  title              String
  description        String
  location           String?
  status             ServiceRequestStatus @default(OPEN)
  selectedProposalId String?              @unique
  expiresAt          DateTime
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  customer           User                 @relation("CustomerServiceRequests", fields: [customerId], references: [id], onDelete: Cascade)
  category           Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  proposals          Proposal[]           @relation("RequestProposals")
  invitations        RequestInvitation[]
  selectedProposal   Proposal?            @relation("SelectedProposal", fields: [selectedProposalId], references: [id], onDelete: SetNull)
  job                Job?

  @@index([customerId, status, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([status, createdAt])
  @@index([status, expiresAt])
}

model RequestInvitation {
  id             String                  @id @default(cuid())
  requestId      String
  providerUserId String
  status         RequestInvitationStatus @default(SENT)
  respondedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  request        ServiceRequest          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  providerUser   User                    @relation("RequestInvitationProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@unique([requestId, providerUserId])
  @@index([requestId, status, createdAt])
  @@index([providerUserId, status, createdAt])
}

model Proposal {
  id                 String          @id @default(cuid())
  requestId          String
  providerId         String
  price              Int
  comment            String?
  status             ProposalStatus  @default(SUBMITTED)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  request            ServiceRequest  @relation("RequestProposals", fields: [requestId], references: [id], onDelete: Cascade)
  provider           User            @relation("ProviderProposals", fields: [providerId], references: [id], onDelete: Cascade)
  selectedForRequest ServiceRequest? @relation("SelectedProposal")
  job                Job?

  @@unique([requestId, providerId])
  @@index([requestId, status, createdAt])
  @@index([providerId, status, createdAt])
}

model Job {
  id                String          @id @default(cuid())
  clientId          String
  customerId        String?
  providerId        String?
  workerProfileId   String
  categoryId        String
  requestId         String?         @unique
  proposalId        String?         @unique
  agreedPrice       Int?
  pricingMode       JobPricingMode  @default(FIXED_PRICE)
  title             String
  description       String
  budget            Int?
  quotedAmount      Int?
  quoteMessage      String?
  status            JobStatus       @default(REQUESTED)
  acceptedAt        DateTime?
  startedAt         DateTime?
  scheduledFor      DateTime?
  completedAt       DateTime?
  canceledAt        DateTime?
  canceledBy        String?
  cancelReason      String?
  contactUnlockedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  client            User            @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  customer          User?           @relation("JobCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  provider          User?           @relation("JobProvider", fields: [providerId], references: [id], onDelete: SetNull)
  workerProfile     WorkerProfile   @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category          Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  request           ServiceRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  proposal          Proposal?       @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  review            Review?
  paymentIntents    PaymentIntent[]
  ledgerEntries     LedgerEntry[]
  payouts           Payout[]
  refundRequests    RefundRequest[]

  @@index([customerId, status, createdAt])
  @@index([providerId, status, createdAt])
  @@index([clientId, status, createdAt])
  @@index([workerProfileId, status, createdAt])
  @@index([status, createdAt])
  @@index([pricingMode, status, createdAt])
}

model Review {
  id              String        @id @default(cuid())
  jobId           String        @unique
  workerProfileId String
  reviewerId      String
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reviewer        User          @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([workerProfileId, createdAt])
  @@index([reviewerId, createdAt])
}

model TrackingWorkerAggregate {
  workerProfileId String    @id
  interactions    Int       @default(0)
  clicks          Int       @default(0)
  ctaClicks       Int       @default(0)
  conversions     Int       @default(0)
  lastEventAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
  @@index([conversions, ctaClicks, clicks])
}

model TrackingCategoryAggregate {
  categorySlug String    @id
  interactions Int       @default(0)
  lastEventAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([updatedAt])
  @@index([interactions])
}

model PaymentIntent {
  id                    String               @id @default(cuid())
  jobId                 String
  customerId            String
  providerUserId        String?
  amount                Int
  currency              String               @default("MZN")
  platformFeeAmount     Int
  providerNetAmount     Int
  status                PaymentIntentStatus  @default(CREATED)
  provider              PaymentProvider      @default(INTERNAL)
  expiresAt             DateTime?
  acceptedQuoteSnapshot Int?
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  job                   Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer              User                 @relation("PaymentIntentCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  providerUser          User?                @relation("PaymentIntentProvider", fields: [providerUserId], references: [id], onDelete: SetNull)
  transactions          PaymentTransaction[]
  ledgerEntries         LedgerEntry[]
  payouts               Payout[]
  refundRequests        RefundRequest[]
  events                PaymentEvent[]

  @@index([jobId, createdAt])
  @@index([customerId, createdAt])
  @@index([providerUserId, createdAt])
  @@index([status, createdAt])
  @@index([provider, status])
}

model PaymentTransaction {
  id                String            @id @default(cuid())
  paymentIntentId   String?
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  provider          PaymentProvider   @default(INTERNAL)
  providerReference String?
  idempotencyKey    String            @unique
  requestedAmount   Int
  confirmedAmount   Int?
  currency          String            @default("MZN")
  providerPayload   Json?
  failureReason     String?
  processedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  paymentIntent     PaymentIntent?    @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  ledgerEntries     LedgerEntry[]
  refundRequests    RefundRequest[]
  events            PaymentEvent[]

  @@unique([provider, providerReference])
  @@index([paymentIntentId, createdAt])
  @@index([status, createdAt])
}

model LedgerEntry {
  id              String              @id @default(cuid())
  jobId           String?
  paymentIntentId String?
  transactionId   String?
  actorType       PaymentActorType
  entryType       LedgerEntryType
  amount          Int
  currency        String              @default("MZN")
  direction       LedgerDirection
  balanceBucket   LedgerBalanceBucket
  description     String?
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  job             Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)
  paymentIntent   PaymentIntent?      @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  transaction     PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdByUser   User?               @relation("LedgerEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([paymentIntentId, createdAt])
  @@index([transactionId, createdAt])
  @@index([balanceBucket, createdAt])
}

model Payout {
  id                String          @id @default(cuid())
  providerUserId    String
  jobId             String?
  paymentIntentId   String?
  amount            Int
  currency          String          @default("MZN")
  status            PayoutStatus    @default(PENDING)
  provider          PaymentProvider @default(INTERNAL)
  providerReference String?
  requestedByUserId String?
  approvedByUserId  String?
  processedAt       DateTime?
  failureReason     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  providerUser      User            @relation("PayoutProviderUser", fields: [providerUserId], references: [id], onDelete: Cascade)
  job               Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  paymentIntent     PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  requestedByUser   User?           @relation("PayoutRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedByUser    User?           @relation("PayoutApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([providerUserId, status, createdAt])
  @@index([status, createdAt])
}

model RefundRequest {
  id                String              @id @default(cuid())
  jobId             String
  paymentIntentId   String
  transactionId     String?
  requestedByUserId String
  approvedByUserId  String?
  amount            Int
  currency          String              @default("MZN")
  reason            String
  status            RefundStatus        @default(PENDING)
  provider          PaymentProvider     @default(INTERNAL)
  providerReference String?
  processedAt       DateTime?
  failureReason     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  job               Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  paymentIntent     PaymentIntent       @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  transaction       PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  requestedByUser   User                @relation("RefundRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  approvedByUser    User?               @relation("RefundApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([paymentIntentId, createdAt])
  @@index([status, createdAt])
}

model PaymentEvent {
  id                String              @id @default(cuid())
  provider          PaymentProvider
  eventType         String
  externalEventId   String?
  providerReference String?
  paymentIntentId   String?
  transactionId     String?
  payload           Json
  signatureValid    Boolean             @default(false)
  processed         Boolean             @default(false)
  processedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  paymentIntent     PaymentIntent?      @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  transaction       PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([provider, createdAt])
  @@index([processed, createdAt])
  @@index([providerReference])
}

enum JobStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum JobPricingMode {
  FIXED_PRICE
  QUOTE_REQUEST
}

enum ServiceRequestStatus {
  OPEN
  CLOSED
  EXPIRED
}

enum ProposalStatus {
  SUBMITTED
  SELECTED
  REJECTED
}

enum RequestInvitationStatus {
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum UserRole {
  USER
  ADMIN
}

enum AdminSubrole {
  SUPPORT_ADMIN
  OPS_ADMIN
  SUPER_ADMIN
}

enum PaymentProvider {
  INTERNAL
  MPESA
  EMOLA
  MKESH
  BANK_TRANSFER
  MANUAL
}

enum PaymentIntentStatus {
  CREATED
  AWAITING_PAYMENT
  PAID_PARTIAL
  PENDING_CONFIRMATION
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELED
}

enum TransactionType {
  CHARGE
  PAYOUT
  REFUND
  REVERSAL
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REVERSED
  CANCELED
}

enum LedgerEntryType {
  CUSTOMER_CHARGE
  PLATFORM_FEE_RESERVED
  PROVIDER_BALANCE_HELD
  PROVIDER_BALANCE_RELEASED
  PROVIDER_PAYOUT
  CUSTOMER_REFUND
  REVERSAL
  ADMIN_ADJUSTMENT
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELED
}

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PaymentActorType {
  CUSTOMER
  PROVIDER
  PLATFORM
  SYSTEM
  ADMIN
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerBalanceBucket {
  CUSTOMER_EXTERNAL
  PLATFORM_RESERVED
  PLATFORM_AVAILABLE
  PROVIDER_HELD
  PROVIDER_AVAILABLE
  PROVIDER_PAID_OUT
}

enum AuditStatus {
  SUCCESS
  DENIED
  FAILED
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  deviceId         String
  refreshTokenHash String    @unique
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([userId, revokedAt])
  @@index([userId, lastUsedAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  status      AuditStatus
  reason      String?
  ipAddress   String?
  userAgent   String?
  route       String
  method      String
  metadata    Json?
  createdAt   DateTime    @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
}

model ReauthChallenge {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  purpose    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PlatformSetting {
  key             String   @id
  value           Json
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedByUser User? @relation("PlatformSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}
