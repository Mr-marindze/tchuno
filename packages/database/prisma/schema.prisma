generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(USER)
  adminSubrole AdminSubrole?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  workerProfile WorkerProfile?
  jobsAsClient Job[]      @relation("ClientJobs")
  reviewsGiven Review[]
  auditLogs AuditLog[]
  reauthChallenges ReauthChallenge[]
  updatedPlatformSettings PlatformSetting[] @relation("PlatformSettingUpdatedBy")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workerProfiles WorkerProfileCategory[]
  jobs        Job[]

  @@index([isActive, sortOrder])
}

model WorkerProfile {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  bio             String?
  location        String?
  hourlyRate      Int?
  experienceYears Int                     @default(0)
  isAvailable     Boolean                 @default(true)
  ratingAvg       Decimal                 @default(0) @db.Decimal(3, 2)
  ratingCount     Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      WorkerProfileCategory[]
  jobs            Job[]
  reviews         Review[]

  @@index([isAvailable, updatedAt])
}

model WorkerProfileCategory {
  workerProfileId String
  categoryId      String
  createdAt       DateTime      @default(now())
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, categoryId])
  @@index([categoryId])
}

model Job {
  id              String       @id @default(cuid())
  clientId        String
  workerProfileId String
  categoryId      String
  pricingMode     JobPricingMode @default(FIXED_PRICE)
  title           String
  description     String
  budget          Int?
  quotedAmount    Int?
  quoteMessage    String?
  status          JobStatus    @default(REQUESTED)
  acceptedAt      DateTime?
  startedAt       DateTime?
  scheduledFor    DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledBy      String?
  cancelReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  client          User         @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  review          Review?

  @@index([clientId, status, createdAt])
  @@index([workerProfileId, status, createdAt])
  @@index([status, createdAt])
  @@index([pricingMode, status, createdAt])
}

model Review {
  id              String        @id @default(cuid())
  jobId           String        @unique
  workerProfileId String
  reviewerId      String
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reviewer        User          @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([workerProfileId, createdAt])
  @@index([reviewerId, createdAt])
}

model TrackingWorkerAggregate {
  workerProfileId String   @id
  interactions    Int      @default(0)
  clicks          Int      @default(0)
  ctaClicks       Int      @default(0)
  conversions     Int      @default(0)
  lastEventAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([updatedAt])
  @@index([conversions, ctaClicks, clicks])
}

model TrackingCategoryAggregate {
  categorySlug String   @id
  interactions Int      @default(0)
  lastEventAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([updatedAt])
  @@index([interactions])
}

enum JobStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum JobPricingMode {
  FIXED_PRICE
  QUOTE_REQUEST
}

enum UserRole {
  USER
  ADMIN
}

enum AdminSubrole {
  SUPPORT_ADMIN
  OPS_ADMIN
  SUPER_ADMIN
}

enum AuditStatus {
  SUCCESS
  DENIED
  FAILED
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  refreshTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([userId, revokedAt])
  @@index([userId, lastUsedAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  status      AuditStatus
  reason      String?
  ipAddress   String?
  userAgent   String?
  route       String
  method      String
  metadata    Json?
  createdAt   DateTime    @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
}

model ReauthChallenge {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  purpose   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PlatformSetting {
  key             String   @id
  value           Json
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedByUser User? @relation("PlatformSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}
