{
  "name": "tchuno",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn dev:api & yarn dev:web",
    "dev:api": "yarn workspace @tchuno/api start:dev",
    "dev:web": "yarn workspace @tchuno/web dev",
    "db:migrate": "yarn workspace @tchuno/database prisma migrate dev",
    "db:seed": "yarn workspace @tchuno/database prisma db seed",
    "lint": "yarn workspaces foreach -Apt run lint",
    "test": "yarn workspaces foreach -Apt run test",
    "test:e2e": "yarn workspace @tchuno/api test:e2e",
    "ci": "yarn lint && yarn test && yarn test:e2e"
  }
}
