POSTGRES_USER=tchuno
POSTGRES_PASSWORD=tchuno
POSTGRES_DB=tchuno

DATABASE_URL="postgresql://tchuno:tchuno@localhost:5432/tchuno?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
API_PORT=3001
WEB_ORIGIN="http://localhost:3000"

NEXT_PUBLIC_API_URL="http://localhost:3001"
NODE_ENV=development

# Payments (foundation + external-ready)
PAYMENT_DEFAULT_PROVIDER=INTERNAL
PAYMENT_WEBHOOK_SECRET="change-me-webhook-secret"
PAYMENT_WEBHOOK_SECRET_MPESA="change-me-mpesa-webhook-secret"
PAYMENT_WEBHOOK_SECRET_EMOLA="change-me-emola-webhook-secret"
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
PAYMENT_WEBHOOK_FUTURE_SKEW_SECONDS=60
PAYMENT_RECONCILE_PROVIDERS="MPESA,EMOLA"
PAYMENT_RECONCILE_BATCH_SIZE=50
PAYMENT_RECONCILE_MIN_AGE_MINUTES=1
PAYMENT_AUTO_RECONCILIATION_ENABLED=true
PAYMENT_AUTO_RECONCILIATION_INTERVAL_MS=60000
PAYMENT_GATEWAY_SETTLEMENT_DELAY_MS=30000
